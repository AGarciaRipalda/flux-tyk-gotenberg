{
  "name": "Gotenberg PDF API",
  "api_id": "gotenberg-v1",
  "org_id": "default",
  "use_keyless": false,
  "use_standard_auth": true,
  "active": true,
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true
      }
    }
  },
  "proxy": {
    "listen_path": "/pdf/",
    "target_url": "http://gotenberg:3000/",
    "strip_listen_path": true
  }
}
